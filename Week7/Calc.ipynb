    "def square(num):\n",
    "    return num ** 2\n",
    "\n",
    "def odd(num):\n",
    "    return num % 2 != 0 \n",
    "\n",
    "def even(num):\n",
    "    return num % 2 == 0\n",
    "\n",
    "print(square(5))\n",
    "print(odd(5))\n",
    "print(even(5))"
   ]
